# Example environment configuration for the extractor-engine CLI.
#
# Every value here is OPTIONAL. With none of these set, the pipeline runs as a
# pure JSONL scraper with zero external infrastructure. CLI flags always override
# these; these in turn override the built-in defaults (CLI > env > default).
#
# Copy to `.env` and uncomment what you need.

# --- Crawl knobs (mirror the CLI flags, prefixed SCRAPER_) ---------------------
# SCRAPER_MAX_PAGES=100          # Hard cap on pages fetched (circuit breaker).
# SCRAPER_MAX_DEPTH=5            # Maximum link depth from the seed.
# SCRAPER_DELAY=0.5             # Seconds to wait between requests (politeness).
# SCRAPER_USER_AGENT=scraper-bot/1.0   # User-Agent sent with every request.

# --- Extraction / enrichment thresholds (advanced; defaults are sensible) ------
# SCRAPER_MIN_WORD_COUNT=25      # Quality-gate floor; also the extractor length floor.
# SCRAPER_LINK_DENSITY_THRESHOLD=0.4   # Over-extraction rejection cutoff.
# SCRAPER_CODE_RATIO_THRESHOLD=0.5     # is_mostly_code cutoff.
# SCRAPER_TIMEOUT=10.0          # Per-request HTTP timeout, seconds.
# SCRAPER_MAX_PAGE_BYTES=5242880       # Response-size cap (~5 MB); 0 disables.

# --- Optional Postgres state backend ------------------------------------------
# When set, enables a resumable Postgres crawl-state store (UPSERT on id).
# The JSONL file remains the deliverable regardless.
# POSTGRES_DSN=postgresql://user:pass@localhost:5432/extractor
